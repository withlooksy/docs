  "forbiddenContentPatterns": [
    {
      "pattern": "\\$169(?:\\/month| per month|\\/mo)",
      "reason": "retired Scale monthly price"
    },
    {
      "pattern": "1,500\\s+(?:monthly\\s+)?(?:try-on\\s+)?credits",
      "reason": "retired Scale credit allowance"
    },
    {
      "pattern": "200\\s+(?:monthly\\s+)?(?:try-on\\s+)?credits",
      "reason": "retired Starter credit allowance"
    },
    {
      "pattern": "Starter(?: plan)?\\s*(?:[:(]|at\\s+|costs?\\s+)\\s*\\$29(?:\\/month| per month|\\/mo)",
      "reason": "retired Starter monthly price"
    },
    {
      "pattern": "Growth(?: plan)?\\s*(?:[:(]|at\\s+|costs?\\s+)\\s*\\$79(?:\\/month| per month|\\/mo)",
      "reason": "retired Growth monthly price"
    },
    {
      "pattern": "\\$0\\.08\\s+(?:per|additional)",
      "reason": "retired additional-credit rate"
    },
    {
      "pattern": "free forever",
      "reason": "unsupported Preview-plan duration claim"
    },
    {
      "pattern": "credits? (?:never expire|roll(?:s|ed)? over)|credit rollover",
      "reason": "unsupported credit-expiry or rollover claim"
    },
    {
      "pattern": "zero performance impact",
      "reason": "unsupported absolute performance claim"
    },
    {
      "pattern": "match(?:es|ing)? real-world fit",
      "reason": "virtual try-on is not a real-world fit guarantee"
    },
    {
      "pattern": "view the result instantly",
      "reason": "unsupported absolute generation-speed claim"
    },
    {
      "pattern": "works? (?:with|on) (?:all|any) (?:Shopify )?themes?",
      "reason": "unsupported universal theme-compatibility claim"
    },
    {
      "pattern": "GDPR and CCPA compliant",
      "reason": "unsupported blanket legal-compliance claim"
    },
    {
      "pattern": "10-20x ROI",
      "reason": "unsupported guaranteed ROI claim"
    }
  ]
