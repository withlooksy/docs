    "profiles": [
      "https://apps.shopify.com/looksy",
      "https://www.linkedin.com/company/withlooksy",
      "https://twitter.com/withlooksy"
    ]
  },
  "plans": [
    {
      "name": "Preview",
      "monthlyPrice": "$0",
      "monthlyCredits": 25,
      "additionalCreditPrice": null,
      "annualPrice": null
    },
    {
      "name": "Starter",
      "monthlyPrice": "$14.99",
      "monthlyCredits": 100,
      "additionalCreditPrice": "$0.14",
      "annualPrice": "$149"
    },
    {
      "name": "Growth",
      "monthlyPrice": "$29",
      "monthlyCredits": 300,
      "additionalCreditPrice": "$0.12",
      "annualPrice": "$290"
    },
    {
      "name": "Scale",
      "monthlyPrice": "$79",
      "monthlyCredits": 600,
      "additionalCreditPrice": "$0.10",
      "annualPrice": "$790"
    }
  ],
  "requiredLiveFiles": [
    "robots.txt",
    "sitemap.xml",
    "llms.txt",
    "llms-full.txt",
